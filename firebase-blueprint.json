{
  "entities": {
    "LitigationCase": {
      "title": "LitigationCase",
      "description": "A single litigation case dossier with complete legal and financial parameters",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID for the case dossier" },
        "updatedAt": { "type": "string", "description": "ISO timestamp of the last revision" },
        "sourceFiles": { "type": "array", "description": "Names of source documents uploaded for tracing and verification" },
        "caseInfo": {
          "type": "object",
          "properties": {
            "caseId": { "type": "string" },
            "taxpayerName": { "type": "string" },
            "ntn": { "type": "string" },
            "strn": { "type": "string" },
            "taxPeriod": { "type": "string" },
            "taxType": { "type": "string" },
            "relevantLegalSections": { "type": "string" },
            "authorityForum": { "type": "string" },
            "documentType": { "type": "string" },
            "referenceNumber": { "type": "string" },
            "documentDate": { "type": "string" }
          },
          "required": ["taxpayerName", "authorityForum", "referenceNumber"]
        },
        "financialInfo": {
          "type": "object",
          "properties": {
            "taxDemand": { "type": "number" },
            "penalty": { "type": "number" },
            "defaultSurcharge": { "type": "number" },
            "refundAmount": { "type": "number" },
            "totalExposure": { "type": "number" }
          }
        },
        "proceedingsInfo": {
          "type": "object",
          "properties": {
            "dateOfNotice": { "type": "string" },
            "dateOfReply": { "type": "string" },
            "hearingDates": { "type": "array" },
            "orderDate": { "type": "string" },
            "appealDate": { "type": "string" },
            "decisionDate": { "type": "string" },
            "currentStage": { "type": "string" }
          }
        },
        "outcomeInfo": {
          "type": "object",
          "properties": {
            "departmentPosition": { "type": "string" },
            "taxpayerPosition": { "type": "string" },
            "decisionSummary": { "type": "string" },
            "reliefGranted": { "type": "string" },
            "amountConfirmed": { "type": "number" },
            "amountDeleted": { "type": "number" },
            "amountRemanded": { "type": "number" },
            "currentStatus": { "type": "string" }
          }
        },
        "chronology": {
          "type": "array",
          "description": "Chronological proceedings milestone log items"
        },
        "createdBy": { "type": "string" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["id", "caseInfo", "financialInfo", "proceedingsInfo", "outcomeInfo"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Role and name information of authorized counsel",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "fullName", "role"]
    }
  },
  "firestore": {
    "/cases/{caseId}": {
      "schema": "LitigationCase",
      "description": "Litigation case collection shared among executive users"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Registered and authorized corporate users and admins"
    }
  }
}
